# ---- Data (keep folder structure, ignore contents) ----
data/raw/structured/**/*
!data/raw/structured/**/.gitkeep

data/cleaned/structured/**/*
!data/cleaned/structured/**/.gitkeep

# ---- Common junk ----
.DS_Store
__pycache__/
*.pyc
.venv/
venv/
.env

# ---- To avoid every plot generated by chart modules being tracked by git
artifacts/plots/*.png
artifacts/plots/*.svg
artifacts/plots/*.pdf
analytics/analysis/artifacts/

# ---------
.claude/
